<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Thomas IT Network Ops</title>
  <script data-tw-accept src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#0984C0',
            secondary: '#1E40AF'
          }
        }
      }
    }
  </script>
</head>
<body class="bg-gradient-to-br from-blue-900 to-indigo-900 min-h-screen">
  <% if flash[:notice] %>
    <div class="fixed top-4 right-4 bg-green-500 text-white px-6 py-3 rounded-lg shadow-lg z-50">
      <%= flash[:notice] %>
    </div>
  <% end %>
  
  <% if flash[:alert] %>
    <div class="fixed top-4 right-4 bg-red-500 text-white px-6 py-3 rounded-lg shadow-lg z-50">
      <%= flash[:alert] %>
    </div>
  <% end %>
  
  <%= yield %>
</body>
</html>
