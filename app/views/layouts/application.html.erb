<!DOCTYPE html>
<html>
<head>
  <title>Thomas IT Network Swap</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="csrf-param" content="authenticity_token" />
  <meta name="csrf-token" content="<%= form_authenticity_token %>" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, sans-serif; line-height: 1.6; }
    .thomas-blue { background: linear-gradient(135deg, #0984C0, #60BDD1); color: white; }
    .thomas-card { background: white; border-radius: 16px; box-shadow: 0 10px 40px rgba(0,0,0,0.1); border: 1px solid #C0BEC6; }
    .btn-primary { background: #0984C0; color: white; padding: 1rem 2rem; border-radius: 12px; text-decoration: none; font-weight: 600; transition: all 0.3s; }
    .btn-primary:hover { background: #075985; transform: translateY(-2px); }
    .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; }
    .status-badge { background: #0984C0; color: white; padding: 0.25rem 0.75rem; border-radius: 999px; font-size: 0.875rem; font-weight: 600; }
  </style>
</head>
<body>
  <%= yield %>
</body>
</html>
