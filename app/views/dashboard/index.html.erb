<!DOCTYPE html>
<html>
<head>
  <title>Thomas IT Network Swap - DJI-PHX-179</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="csrf-token" content="<%= form_authenticity_token %>">
</head>
<body style="margin:0;min-height:100vh;background:radial-gradient(circle at top,#0f172a,#020617);font-family:system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;color:#e5e7eb;display:flex;align-items:center;justify-content:center;">

  <div style="width:100%;max-width:800px;padding:2.5rem;border-radius:1.5rem;background:rgba(15,23,42,0.9);box-shadow:0 25px 70px rgba(15,23,42,0.95);backdrop-filter:blur(20px);border:1px solid rgba(148,163,184,0.3);">
    
    <!-- Header -->
    <header style="text-align:center;margin-bottom:2.5rem;">
      <h1 style="margin:0 0 0.5rem;font-size:2.5rem;font-weight:800;background:linear-gradient(135deg,#22c55e,#06b6d4);background-clip:text;-webkit-background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:-0.02em;">
        🚁 DJI-PHX-179 Live
      </h1>
      <p style="margin:0;font-size:1.1rem;color:#94a3b8;">
        Autonomous Phoenix DC rack inspections • Phase 14 LIVE
      </p>
    </header>

    <!-- Status Cards -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.5rem;margin-bottom:2.5rem;">
      
      <!-- Battery -->
      <div style="padding:1.5rem;border-radius:1rem;background:rgba(34,197,94,0.15);border:1px solid rgba(34,197,94,0.3);">
        <h3 style="margin:0 0 0.5rem;font-size:0.9rem;color:#10b981;font-weight:600;">Battery</h3>
        <div style="font-size:2.5rem;font-weight:700;color:#059669;">85%</div>
      </div>

      <!-- Racks -->
      <div style="padding:1.5rem;border-radius:1rem;background:rgba(251,191,36,0.15);border:1px solid rgba(251,191,36,0.3);">
        <h3 style="margin:0 0 0.5rem;font-size:0.9rem;color:#d97706;font-weight:600;">Racks Scanned</h3>
        <div style="font-size:2.5rem;font-weight:700;color:#b45309;">8/12</div>
      </div>

      <!-- Alerts -->
      <div style="padding:1.5rem;border-radius:1rem;background:rgba(30,64,175,0.15);border:1px solid rgba(30,64,175,0.3);">
        <h3 style="margin:0 0 0.5rem;font-size:0.9rem;color:#1e40af;font-weight:600;">Thermal Alerts</h3>
        <div style="font-size:2.5rem;font-weight:700;color:#1e3a8a;">0</div>
      </div>

    </div>

    <!-- Drone Scan Button -->
    <div style="text-align:center;">
      <form action="/api/v1/inspections" method="post" style="display:inline;">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <button type="submit"
          style="padding:1rem 2.5rem;border-radius:999px;border:none;background:linear-gradient(135deg,#22c55e,#16a34a);color:#022c22;font-weight:700;font-size:1.1rem;cursor:pointer;box-shadow:0 15px 40px rgba(34,197,94,0.5);transition:all 0.2s;"
          onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 20px 50px rgba(34,197,94,0.6)';"
          onmouseout="this.style.transform='';this.style.boxShadow='0 15px 40px rgba(34,197,94,0.5)';">
          🚁 RUN DRONE SCAN NOW
        </button>
      </form>
    </div>

    <!-- Footer -->
    <p style="margin-top:2rem;font-size:0.85rem;color:#6b7280;text-align:center;">
      Field Tech: Brett Thomas ✓ | Phoenix, AZ | <%= Time.now.strftime("%Y-%m-%d %H:%M MST") %>
    </p>

  </div>

</body>
</html>
