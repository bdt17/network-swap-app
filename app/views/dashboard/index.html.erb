<div class="min-h-screen bg-gradient-to-br from-gray-900 via-blue-900 to-indigo-900 p-8 text-white">
  <div class="max-w-7xl mx-auto">
    
    <!-- HEADER -->
    <div class="flex justify-between items-center mb-12">
      <div>
        <h1 class="text-5xl md:text-7xl font-black bg-gradient-to-r from-white to-blue-200 bg-clip-text text-transparent mb-4">
          Thomas IT Network Operations Center
        </h1>
        <p class="text-xl opacity-90">Phoenix DC21 • Live: <%= Time.now.strftime("%m/%d %H:%M MST") %></p>
      </div>
      <div class="flex gap-4">
        <a href="/dashboard/tech" class="px-8 py-3 bg-indigo-600 hover:bg-indigo-700 rounded-2xl font-bold text-lg">🔧 Tech Portal</a>
        <a href="/api/devices/export.csv" class="px-8 py-3 bg-emerald-600 hover:bg-emerald-700 rounded-2xl font-bold text-lg">📊 CSV Export</a>
      </div>
    </div>

    <!-- METRICS GRID -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-16">
      <div class="bg-white/5 backdrop-blur-xl border border-white/20 rounded-3xl p-8 hover:bg-white/10 transition-all group">
        <div class="text-4xl mb-4">📊</div>
        <h3 class="text-4xl font-black text-blue-400 mb-2 group-hover:text-blue-300">247</h3>
        <p class="text-lg opacity-75">Devices</p>
        <a href="/dashboard/tech" class="text-indigo-400 hover:text-indigo-300 font-bold text-sm mt-2 block">View →</a>
      </div>
      
      <div class="bg-white/5 backdrop-blur-xl border border-white/20 rounded-3xl p-8 hover:bg-white/10 transition-all group">
        <div class="text-4xl mb-4">🚁</div>
        <h3 class="text-4xl font-black text-emerald-400 mb-2 group-hover:text-emerald-300">2</h3>
        <p class="text-lg opacity-75">Drones</p>
        <a href="#" class="text-emerald-400 hover:text-emerald-300 font-bold text-sm mt-2 block">DJI Telemetry →</a>
      </div>
      
      <div class="bg-white/5 backdrop-blur-xl border border-white/20 rounded-3xl p-8 hover:bg-white/10 transition-all group">
        <div class="text-4xl mb-4">🔧</div>
        <h3 class="text-4xl font-black text-purple-400 mb-2 group-hover:text-purple-300">14</h3>
        <p class="text-lg opacity-75">Sites</p>
        <a href="#" class="text-purple-400 hover:text-purple-300 font-bold text-sm mt-2 block">Site Status →</a>
      </div>
      
      <div class="bg-white/5 backdrop-blur-xl border border-white/20 rounded-3xl p-8 hover:bg-white/10 transition-all group">
        <div class="text-4xl mb-4">📦</div>
        <h3 class="text-4xl font-black text-orange-400 mb-2 group-hover:text-orange-300">23</h3>
        <p class="text-lg opacity-75">Swaps</p>
        <a href="#" class="text-orange-400 hover:text-orange-300 font-bold text-sm mt-2 block">Swap History →</a>
      </div>
    </div>

    <!-- LIVE STATUS CARDS -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-16">
      <!-- DJI DRONE STATUS -->
      <div class="bg-gradient-to-br from-emerald-500/20 to-emerald-600/20 border-2 border-emerald-500/50 rounded-3xl p-8">
        <h2 class="text-2xl font-black mb-6 flex items-center gap-3">
          🚁 <span>DJI-PHX-179 Live Status</span>
          <span class="px-3 py-1 bg-emerald-500/90 text-white rounded-full text-sm font-bold">87% Battery</span>
        </h2>
        <div class="space-y-4 text-lg">
          <div><span class="opacity-75">Status:</span> <span class="font-bold text-emerald-400">Scanning Phoenix DC21</span></div>
          <div><span class="opacity-75">Signal:</span> <span class="font-bold text-emerald-400">5/5 Bars</span></div>
          <div><span class="opacity-75">Last Scan:</span> <span class="font-bold">Rack 3U Complete</span></div>
        </div>
      </div>

      <!-- CRITICAL ALERT -->
      <div class="bg-gradient-to-br from-red-500/20 to-red-600/20 border-4 border-red-500/50 rounded-3xl p-8 animate-pulse">
        <h2 class="text-2xl font-black mb-6 flex items-center gap-3">
          🚨 Rack 3U-B2 Thermal Alert
          <span class="px-4 py-2 bg-red-600 text-white rounded-2xl font-bold text-lg">HIGH PRIORITY</span>
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <p class="text-3xl font-black text-red-400 mb-2">42°C</p>
            <p class="text-lg opacity-90">(Threshold: 35°C)</p>
          </div>
          <div class="flex gap-4 pt-2">
            <a href="/api/dispatch_sms?tech=Brett+Thomas&device=Rack3U-B2&issue=Thermal+Alert" 
               class="flex-1 px-6 py-4 bg-red-600 hover:bg-red-700 text-white font-bold rounded-2xl text-center text-lg shadow-2xl">
              🚨 Dispatch SMS
            </a>
            <button class="px-6 py-4 bg-gray-700 hover:bg-gray-600 text-white font-bold rounded-2xl text-lg">
              ⏸️ Snooze 1h
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- RECENT ACTIVITY -->
    <div class="bg-white/5 backdrop-blur-xl border border-white/20 rounded-3xl p-8">
      <h2 class="text-3xl font-black mb-8 flex items-center gap-4">📋 Recent Activity</h2>
      <div class="space-y-4">
        <div class="flex items-center gap-4 p-4 bg-white/5 rounded-2xl hover:bg-white/10 transition-all">
          <div class="w-12 h-12 bg-orange-500/20 rounded-xl flex items-center justify-center">
            <span class="text-xl font-bold text-orange-400">👤</span>
          </div>
          <div class="flex-1">
            <p class="font-bold">Smith, J. claimed #2001 Cisco 9300 EOL</p>
            <p class="text-sm opacity-75">2 hours ago</p>
          </div>
        </div>
        <div class="flex items-center gap-4 p-4 bg-white/5 rounded-2xl hover:bg-white/10 transition-all">
          <div class="w-12 h-12 bg-emerald-500/20 rounded-xl flex items-center justify-center">
            <span class="text-xl font-bold text-emerald-400">🚁</span>
          </div>
          <div class="flex-1">
            <p class="font-bold">DJI-PHX-179 scan complete - Rack 3U</p>
            <p class="text-sm opacity-75">45 minutes ago</p>
          </div>
        </div>
        <div class="flex items-center gap-4 p-4 bg-white/5 rounded-2xl hover:bg-white/10 transition-all">
          <div class="w-12 h-12 bg-blue-500/20 rounded-xl flex items-center justify-center">
            <span class="text-xl font-bold text-blue-400">📦</span>
          </div>
          <div class="flex-1">
            <p class="font-bold">25 devices shipped CDW ETA 3/1</p>
            <p class="text-sm opacity-75">1 day ago</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
