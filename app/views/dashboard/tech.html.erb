<div class="p-8 bg-gradient-to-r from-blue-50 to-indigo-100 min-h-screen">
  <h1 class="text-4xl font-bold text-gray-900 mb-8">Tech Dashboard - Phoenix DC21</h1>
  
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
    <% @devices.each do |device| %>
      <div class="bg-white p-6 rounded-xl shadow-lg hover:shadow-2xl transition-all duration-300">
        <h3 class="text-xl font-semibold text-gray-900 mb-3"><%= device.name %></h3>
        <div class="flex items-center space-x-3 mb-4">
          <span class="px-4 py-2 rounded-full text-sm font-semibold 
            <%= case device.status
                when 'operational' then 'bg-emerald-100 text-emerald-800'
                when 'needs_firmware' then 'bg-amber-100 text-amber-800' 
                when 'EOL' then 'bg-red-100 text-red-800'
                else 'bg-gray-100 text-gray-800'
                end %>">
            <%= device.status.gsub('_', ' ').titleize %>
          </span>
        </div>
        <div class="text-sm text-gray-600 space-y-1">
          <p><strong>Status:</strong> <%= device.status.humanize %></p>
          <p><strong>Site:</strong> Phoenix DC21</p>
        </div>
      </div>
    <% end %>
  </div>

  <div class="bg-white p-8 rounded-xl shadow-lg">
    <h2 class="text-2xl font-bold mb-6">DJI Drone Fleet</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <% @drones.each do |drone| %>
        <div class="p-4 bg-gray-50 rounded-lg">
          <h4 class="font-semibold"><%= drone.identifier %></h4>
          <p>Battery: <%= drone.battery_level || 'N/A' %>%</p>
          <p>Status: <%= drone.status || 'Unknown' %></p>
        </div>
      <% end %>
    </div>
  </div>
</div>
