<!DOCTYPE html>
<html>
<head>
  <title>Thomas IT Network Swap - Tech Dashboard</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="csrf-token" content="<%= form_authenticity_token %>">
  <style>
    :root {
      --primary-blue: #0984C0;    /* Deep Ocean Blue */
      --accent-silver: #AAA7B0;   /* Metallic Silver */
      --mid-grey: #565759;        /* Davy's Grey */
      --bg-white: #FFFFFF;        /* Pure White */
      --light-silver: #C0BEC6;    /* Silver Sand */
      --lighter-blue: #60BDD1;    /* Sea Serpent */
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
      background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
      min-height: 100vh;
      color: var(--mid-grey);
    }
  </style>
</head>
<body>
  <div style="max-width: 1400px; margin: 0 auto; padding: 2rem;">
    
    <!-- Header -->
    <header style="text-align: center; margin-bottom: 3rem;">
      <h1 style="font-size: 2.5rem; font-weight: 800; background: linear-gradient(135deg, var(--primary-blue), var(--lighter-blue)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 0.5rem;">
        🛠️ Tech Dashboard LIVE
      </h1>
      <p style="font-size: 1.1rem; color: var(--accent-silver);">
        Thomas IT Network Swap • Field Operations • Phase 8 LIVE
      </p>
    </header>

    <!-- Stats Grid -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-bottom: 3rem;">
      <div style="background: var(--bg-white); padding: 1.5rem; border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); border: 1px solid var(--light-silver);">
        <div style="font-size: 0.9rem; color: var(--accent-silver); font-weight: 600; margin-bottom: 0.5rem;">Devices</div>
        <div style="font-size: 2.5rem; font-weight: 800; color: var(--primary-blue);">500</div>
      </div>
      <div style="background: var(--bg-white); padding: 1.5rem; border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); border: 1px solid var(--light-silver);">
        <div style="font-size: 0.9rem; color: var(--accent-silver); font-weight: 600; margin-bottom: 0.5rem;">Sites</div>
        <div style="font-size: 2.5rem; font-weight: 800; color: var(--primary-blue);">5</div>
      </div>
      <div style="background: var(--bg-white); padding: 1.5rem; border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); border: 1px solid var(--light-silver);">
        <div style="font-size: 0.9rem; color: var(--accent-silver); font-weight: 600; margin-bottom: 0.5rem;">Swap Tickets</div>
        <div style="font-size: 2.5rem; font-weight: 800; color: var(--primary-blue);">25</div>
      </div>
      <div style="background: var(--bg-white); padding: 1.5rem; border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); border: 1px solid var(--light-silver);">
        <div style="font-size: 0.9rem; color: var(--accent-silver); font-weight: 600; margin-bottom: 0.5rem;">Open Jobs</div>
        <div style="font-size: 2.5rem; font-weight: 800; color: var(--primary-blue);">42</div>
      </div>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 400px; gap: 2rem; align-items: start;">
      
      <!-- LEFT: Swap Tickets -->
      <div>
        <h2 style="font-size: 1.5rem; font-weight: 700; color: var(--primary-blue); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem;">
          📋 Active Swap Tickets
        </h2>
        
        <!-- Ticket Cards -->
        <div style="display: grid; gap: 1rem;">
          
          <!-- Ticket #2001 -->
          <div style="background: var(--bg-white); border-radius: 16px; padding: 1.5rem; box-shadow: 0 10px 30px rgba(0,0,0,0.1); border-left: 4px solid var(--primary-blue); position: relative;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
              <div>
                <span style="background: var(--primary-blue); color: white; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.8rem; font-weight: 600;">#2001</span>
              </div>
              <div style="font-size: 0.85rem; color: var(--accent-silver);">Cisco Catalyst 9300</div>
            </div>
            <h3 style="font-size: 1.25rem; font-weight: 700; color: var(--mid-grey); margin-bottom: 0.5rem;">PHX-DC21 Rack 3B</h3>
            <div style="display: flex; gap: 1rem; margin-bottom: 1rem;">
              <span style="color: var(--accent-silver);">Status:</span>
              <span style="background: #10b981; color: white; padding: 0.25rem 0.75rem; border-radius: 12px; font-size: 0.8rem;">Ready</span>
            </div>
            <button style="background: var(--primary-blue); color: white; border: none; padding: 0.75rem 1.5rem; border-radius: 12px; font-weight: 600; cursor: pointer; width: 100%; margin-bottom: 0.5rem;">
              CLAIM THIS JOB
            </button>
          </div>

          <!-- Ticket #2002 -->
          <div style="background: var(--bg-white); border-radius: 16px; padding: 1.5rem; box-shadow: 0 10px 30px rgba(0,0,0,0.1); border-left: 4px solid var(--lighter-blue); position: relative;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
              <div>
                <span style="background: var(--lighter-blue); color: white; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.8rem; font-weight: 600;">#2002</span>
              </div>
              <div style="font-size: 0.85rem; color: var(--accent-silver);">Aruba AP-515</div>
            </div>
            <h3 style="font-size: 1.25rem; font-weight: 700; color: var(--mid-grey); margin-bottom: 0.5rem;">PHX-DC21 Rack 5A</h3>
            <div style="display: flex; gap: 1rem; margin-bottom: 1rem;">
              <span style="color: var(--accent-silver);">Status:</span>
              <span style="background: #f59e0b; color: white; padding: 0.25rem 0.75rem; border-radius: 12px; font-size: 0.8rem;">Scheduled</span>
            </div>
            <button style="background: var(--lighter-blue); color: white; border: none; padding: 0.75rem 1.5rem; border-radius: 12px; font-weight: 600; cursor: pointer; width: 100%; margin-bottom: 0.5rem;">
              CLAIM THIS JOB
            </button>
          </div>

        </div>
      </div>

      <!-- RIGHT: DJI Drone Panel -->
      <div style="background: linear-gradient(135deg, rgba(9,132,192,0.1), rgba(96,189,209,0.1)); border-radius: 20px; padding: 2rem; border: 1px solid rgba(9,132,192,0.2);">
        <div style="text-align: center; margin-bottom: 2rem;">
          <div style="display: inline-flex; align-items: center; gap: 0.5rem; background: rgba(9,132,192,0.2); padding: 0.5rem 1rem; border-radius: 20px; margin-bottom: 1rem;">
            <div style="width: 8px; height: 8px; background: #10b981; border-radius: 50%; animation: pulse 2s infinite;"></div>
            <span style="color: var(--primary-blue); font-weight: 700; font-size: 0.9rem;">PHASE 14 • LIVE</span>
          </div>
          <h2 style="font-size: 2rem; font-weight: 800; background: linear-gradient(135deg, var(--primary-blue), var(--lighter-blue)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
            🚁 DJI-PHX-179
          </h2>
        </div>

        <!-- Drone Stats -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem;">
          <div style="text-align: center; padding: 1rem; background: rgba(255,255,255,0.7); border-radius: 12px;">
            <div style="font-size: 3rem; font-weight: 800; color: #10b981;">85%</div>
            <div style="font-size: 0.85rem; color: var(--mid-grey);">Battery</div>
          </div>
          <div style="text-align: center; padding: 1rem; background: rgba(255,255,255,0.7); border-radius: 12px;">
            <div style="font-size: 3rem; font-weight: 800; color: #f59e0b;">8/12</div>
            <div style="font-size: 0.85rem; color: var(--mid-grey);">Racks Scanned</div>
          </div>
          <div style="text-align: center; padding: 1rem; background: rgba(255,255,255,0.7); border-radius: 12px; grid-column: span 2;">
            <div style="font-size: 3rem; font-weight: 800; color: #3b82f6;">0</div>
            <div style="font-size: 0.85rem; color: var(--mid-grey);">Thermal Alerts</div>
          </div>
        </div>

        <!-- Drone Scan Button -->
        <form action="/api/v1/inspections" method="post" style="text-align: center;">
          <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
          <button type="submit" style="
            width: 100%; padding: 1rem 2rem; border: none; border-radius: 16px; 
            background: linear-gradient(135deg, var(--primary-blue), var(--lighter-blue));
            color: white; font-weight: 700; font-size: 1.1rem; cursor: pointer;
            box-shadow: 0 10px 30px rgba(9,132,192,0.4);
            transition: all 0.3s ease;
          ">
            🚁 RUN DRONE SCAN NOW
          </button>
        </form>

        <p style="text-align: center; margin-top: 1.5rem; font-size: 0.85rem; color: var(--accent-silver);">
          Field Tech: Brett Thomas ✓ | Phoenix, AZ | <%= Time.now.strftime("%Y-%m-%d %H:%M MST") %>
        </p>
      </div>
    </div>

    <!-- Quick Actions -->
    <div style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--light-silver);">
      <h3 style="font-size: 1.25rem; font-weight: 700; color: var(--primary-blue); margin-bottom: 1.5rem;">
        ⚡ Quick Actions
      </h3>
      <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
        <button style="background: var(--primary-blue); color: white; border: none; padding: 0.75rem 1.5rem; border-radius: 12px; font-weight: 600; cursor: pointer;">Create Swap</button>
        <button style="background: #10b981; color: white; border: none; padding: 0.75rem 1.5rem; border-radius: 12px; font-weight: 600; cursor: pointer;">Claim Job</button>
        <button style="background: #ef4444; color: white; border: none; padding: 0.75rem 1.5rem; border-radius: 12px; font-weight: 600; cursor: pointer;">Dispatch Tower</button>
        <button style="background: var(--accent-silver); color: var(--mid-grey); border: none; padding: 0.75rem 1.5rem; border-radius: 12px; font-weight: 600; cursor: pointer;">Refresh</button>
      </div>
    </div>
  </div>

  <style>
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.5; }
    }
  </style>
</body>
</html>
