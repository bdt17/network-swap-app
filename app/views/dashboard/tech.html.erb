<!DOCTYPE html>
<html>
<head>
  <title>DJI-PHX-179 Dashboard</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
</head>
<body style="margin:0;min-height:100vh;background:linear-gradient(135deg,#0f172a 0%,#1e293b 100%);color:white;padding:2rem;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;">
  <div style="max-width:1200px;margin:0 auto;">
    <h1 style="font-size:3rem;text-align:center;font-weight:800;background:linear-gradient(135deg,#3b82f6,#10b981);-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin:0 0 1rem;">
      DJI-PHX-179 Status
    </h1>
    <p style="text-align:center;font-size:1.2rem;color:#94a3b8;margin:0 0 3rem;">
      Field Tech: Brett Thomas ✓ | <%= Time.now.strftime("%Y-%m-%d %H:%M") %> MST
    </p>
    
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:2rem;">
      <div style="background:rgba(255,255,255,0.1);backdrop-filter:blur(20px);padding:2rem;border-radius:24px;border:1px solid rgba(255,255,255,0.2);">
        <h2 style="font-size:1.5rem;margin:0 0 1rem;color:#f8fafc;">Battery</h2>
        <div style="font-size:3rem;font-weight:700;color:#10b981;"><%= @dji_status[:battery] %></div>
        <div style="width:100%;height:12px;background:rgba(255,255,255,0.2);border-radius:6px;overflow:hidden;margin-top:1rem;">
          <div style="width:<%= @dji_status[:battery].gsub('%','') %>;height:100%;background:linear-gradient(90deg,#10b981,#059669);"></div>
        </div>
      </div>
      
      <div style="background:rgba(255,255,255,0.1);backdrop-filter:blur(20px);padding:2rem;border-radius:24px;border:1px solid rgba(255,255,255,0.2);">
        <h2 style="font-size:1.5rem;margin:0 0 1rem;color:#f8fafc;">Racks</h2>
        <div style="font-size:3rem;font-weight:700;color:#f59e0b;"><%= @dji_status[:racks] %></div>
        <div style="color:#94a3b8;margin-top:0.5rem;">37.5% loaded</div>
      </div>
      
      <div style="background:rgba(255,255,255,0.1);backdrop-filter:blur(20px);padding:2rem;border-radius:24px;border:1px solid rgba(255,255,255,0.2);">
        <h2 style="font-size:1.5rem;margin:0 0 1rem;color:#f8fafc;">Thermal Alerts</h2>
        <div style="font-size:4rem;color:#10b981;">0</div>
        <div style="color:#10b981;font-weight:600;">All systems nominal</div>
      </div>
    </div>
  </div>
</body>
</html>
