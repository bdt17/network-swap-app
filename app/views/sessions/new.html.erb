<div class="min-h-screen bg-gradient-to-br from-blue-900 to-blue-800 flex items-center justify-center">
  <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-12 shadow-2xl border border-white/20 max-w-md w-full mx-4">
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold bg-gradient-to-r from-blue-400 to-purple-500 bg-clip-text text-transparent mb-4">
        Thomas IT
      </h1>
      <p class="text-blue-100 text-xl">Network Operations Center</p>
    </div>
    
    <%= form_with url: session_path, local: true do |f| %>
      <div class="space-y-6">
        <%= f.label :username, "Username", class: "block text-blue-100 font-medium mb-2" %>
        <%= f.email_field :username, class: "w-full p-4 bg-white/20 border border-white/30 rounded-xl text-white placeholder-blue-200 focus:ring-2 focus:ring-blue-400 focus:border-transparent transition-all", placeholder: "admin", required: true %>
        
        <%= f.label :password, "Password", class: "block text-blue-100 font-medium mb-2" %>
        <%= f.password_field :password, class: "w-full p-4 bg-white/20 border border-white/30 rounded-xl text-white placeholder-blue-200 focus:ring-2 focus:ring-blue-400 focus:border-transparent transition-all", placeholder: "thomasit", required: true %>
        
        <%= f.submit "Enter Network Ops", class: "w-full bg-gradient-to-r from-blue-500 to-purple-600 hover:from-blue-600 hover:to-purple-700 text-white font-bold py-4 px-8 rounded-xl shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 transition-all duration-200 text-lg" %>
      </div>
    <% end %>
    
    <div class="mt-8 text-center text-blue-200 text-sm">
      DJI-PHX-179 scanning Phoenix DC21 racks | 247 devices active
    </div>
  </div>
</div>
